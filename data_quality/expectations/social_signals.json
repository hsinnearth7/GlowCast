{
  "expectation_suite_name": "glowcast_fact_social_signals",
  "data_asset_type": "Dataset",
  "meta": {
    "great_expectations_version": "0.18.0",
    "description": "Expectations for the Fact_Social_Signals table — Reddit, TikTok, and @cosme social signal data with T-3 lag cross-correlation to sales.",
    "owner": "glowcast-data-team"
  },
  "expectations": [
    {
      "expectation_type": "expect_table_columns_to_match_ordered_list",
      "kwargs": {
        "column_list": [
          "date",
          "sku_id",
          "platform",
          "mentions",
          "sentiment_score",
          "engagement_rate",
          "trending_flag"
        ]
      }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 100,
        "max_value": 20000000
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "date"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "sku_id"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "platform"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "platform",
        "value_set": [
          "reddit",
          "tiktok",
          "cosme"
        ]
      },
      "meta": {
        "notes": "Three social platforms: Reddit, TikTok, @cosme (Japan)"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "mentions",
        "min_value": 0,
        "max_value": 100000,
        "mostly": 0.999
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "sentiment_score",
        "min_value": -1.0,
        "max_value": 1.0
      },
      "meta": {
        "notes": "Normalized sentiment: -1 (negative) to +1 (positive)"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "engagement_rate",
        "min_value": 0.0,
        "max_value": 1.0,
        "mostly": 0.99
      },
      "meta": {
        "notes": "Engagement as ratio (0-1)"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "trending_flag",
        "value_set": [0, 1]
      }
    },
    {
      "expectation_type": "expect_column_mean_to_be_between",
      "kwargs": {
        "column": "sentiment_score",
        "min_value": -0.5,
        "max_value": 0.8
      },
      "meta": {
        "notes": "Beauty products tend toward positive sentiment"
      }
    },
    {
      "expectation_type": "expect_column_mean_to_be_between",
      "kwargs": {
        "column": "trending_flag",
        "min_value": 0.01,
        "max_value": 0.20
      },
      "meta": {
        "notes": "Only 1-20% of entries should be trending at any time"
      }
    }
  ],
  "ge_cloud_id": null
}
