{
  "expectation_suite_name": "glowcast_fact_sales",
  "data_asset_type": "Dataset",
  "meta": {
    "great_expectations_version": "0.18.0",
    "description": "Expectations for the Fact_Sales table — daily demand, revenue, and unit sales per SKU per fulfillment center.",
    "owner": "glowcast-data-team"
  },
  "expectations": [
    {
      "expectation_type": "expect_table_columns_to_match_ordered_list",
      "kwargs": {
        "column_list": [
          "date",
          "sku_id",
          "fc_id",
          "units_sold",
          "revenue",
          "units_returned",
          "promo_flag",
          "treatment_flag"
        ]
      },
      "meta": {
        "notes": "Schema enforcement — all 8 columns must be present in order"
      }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 1000,
        "max_value": 50000000
      },
      "meta": {
        "notes": "Full dataset has ~5000 SKUs × 12 FCs × 730 days = ~43M rows"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "date"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "sku_id"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "fc_id"
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "sku_id",
        "regex": "^SKU_\\d{4,5}$"
      },
      "meta": {
        "notes": "SKU IDs follow pattern SKU_0001 to SKU_5000"
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "fc_id",
        "regex": "^FC_(US|DE|UK|JP|IN)_\\d{2}$"
      },
      "meta": {
        "notes": "12 FCs across 5 countries: US, DE, UK, JP, IN"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "units_sold",
        "min_value": 0,
        "max_value": 10000,
        "mostly": 0.999
      },
      "meta": {
        "notes": "Non-negative demand; 30%+ SKUs have zero-demand days (Negative Binomial)"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "revenue",
        "min_value": 0.0,
        "max_value": 500000.0,
        "mostly": 0.999
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "units_returned",
        "min_value": 0,
        "max_value": 5000,
        "mostly": 0.999
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "promo_flag",
        "value_set": [0, 1]
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "treatment_flag",
        "value_set": [0, 1]
      }
    },
    {
      "expectation_type": "expect_column_proportion_of_unique_values_to_be_between",
      "kwargs": {
        "column": "sku_id",
        "min_value": 0.0001,
        "max_value": 1.0
      },
      "meta": {
        "notes": "Many SKUs but repeated across dates and FCs"
      }
    },
    {
      "expectation_type": "expect_column_mean_to_be_between",
      "kwargs": {
        "column": "treatment_flag",
        "min_value": 0.15,
        "max_value": 0.25
      },
      "meta": {
        "notes": "20/80 treatment/control split — mean should be ~0.20"
      }
    }
  ],
  "ge_cloud_id": null
}
